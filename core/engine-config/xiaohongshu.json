{
  "_comment": "小红书搜索配置",
  "id": "xiaohongshu",
  "name": "Xiaohongshu",
  "baseUrl": "https://www.xiaohongshu.com",
  "searchPath": "/search_result/?keyword={query}&source=web_search_result_notes&type=51",
  "selectors": {
    "_comment_resultContainer": "笔记容器选择器",
    "resultContainer": "section.note-item:not([data-type='live']):not([data-type='advertisement']), .note-item:not(.live-card):not(.ad-card)",
    "_comment_title": "从容器 innerText 获取第一行作为标题",
    "title": "a[class='cover'] .title, .footer a, .note-item a",
    "_comment_link": "优先使用 /explore/ 链接（笔记ID），即使隐藏也可访问",
    "link": "a[href^='/explore/'], a[href*='xiaohongshu.com/explore/']",
    "snippet": ".desc, .note-desc, .content-desc, .note-text, .footer"
  },
  "headers": {
    "Accept-Language": "zh-CN,zh;q=0.9",
    "Referer": "https://www.xiaohongshu.com/"
  },
  "antiBot": {
    "enabled": true,
    "detectors": [
      "[class*='captcha' i]",
      "[class*='verify' i]",
      "text=安全验证",
      "text=请完成验证",
      "text=请先登录"
    ],
    "errorMessage": "小红书检测到验证或登录门槛，需要补充本地登录态后重试。"
  },
  "customDelay": {
    "min": 3000,
    "max": 5000
  },
  "fallbackSelector": "section.note-item",
  "linkValidation": ["xiaohongshu.com/explore", "/explore/"],
  "linkExclusion": ["/livelist", "/live/", "/notification", "/search_result"],
  "maxResultsPerPage": 20,
  "timezoneList": ["Asia/Shanghai"],
  "localeList": ["zh-CN"],
  "notes": {
    "_comment_urlFormat": "小红书网页端详情页 URL 需要 xsec_token 参数",
    "urlFormat": "https://www.xiaohongshu.com/explore/{note_id}?xsec_token={token}&xsec_source=pc_search",
    "hint": "直接访问 /explore/{id} 可能跳转到 404，需要从搜索结果页获取完整的带 token 的 URL"
  }
}
