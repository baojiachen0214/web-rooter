# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.spec

# Virtual environments
.venv/
.venv*/
venv/
venv*/
env/
env*/

# =============================================================================
# IDE and Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Environment files
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Claude Code
# =============================================================================
.claude/
CLAUDE.md
claude-code-mcp.json
.mcp.json

# =============================================================================
# Web-Rooter Runtime Data (DO NOT COMMIT)
# =============================================================================
.web-rooter/
memory/

# =============================================================================
# AI Agent Skill Files (auto-generated by setup_ai_skills.py)
# These are injected at runtime and should NOT be committed
# =============================================================================
AGENTS.md
.openclaw/
.opencode/
.cursor/rules/

# =============================================================================
# Temporary files
# =============================================================================
temp/
*.tmp
.cache/

# =============================================================================
# Test outputs (exclude root-level test files, keep tests/ directory)
# =============================================================================
test_*.py
deep_test*.py
!tests/test_*.py
.pytest_cache/

# =============================================================================
# Examples (keep minimal, exclude detailed examples)
# =============================================================================
examples/*
!examples/claude/
!examples/claude/claude-code-mcp.example.json

# =============================================================================
# Local reports (keep local, do not push)
# =============================================================================
docs/reports/*
!docs/reports/.gitkeep

# =============================================================================
# User-specific profiles and configs (keep templates)
# =============================================================================
profiles/auth/*.json
!profiles/auth/*.template.json
profiles/challenge_profiles/*.json
!profiles/challenge_profiles/*.template.json
profiles/micro_skills/*.json
!profiles/micro_skills/*.template.json
!profiles/micro_skills/README.md
profiles/skills/*.json
!profiles/skills/*.template.json
!profiles/skills/README.md
profiles/workflows/*.json
!profiles/workflows/*.template.json

# =============================================================================
# Analysis reports (auto-generated)
# =============================================================================
*_ANALYSIS.md
*_SUMMARY.md
*_IMPROVEMENTS.md

# =============================================================================
# pip output files (stray files from pip commands)
# =============================================================================
# pip prints "Requirement already satisfied: x in y (version)" which can land in CWD
=*.txt
=*.md
=*/
=*.*)

# =============================================================================
# Secrets and credentials (NEVER commit)
# =============================================================================
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
*secret*
*apikey*
